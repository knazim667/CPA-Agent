# ── Model Provider ───────────────────────────────────────────────────────────
# Options: ollama | openai | gemini | openrouter
MODEL_PROVIDER=openrouter

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=tencent/hy3-preview:free

# ── Google Workspace ──────────────────────────────────────────────────────────
# Place your downloaded OAuth client JSON here, then run: python authorize_google_oauth.py
GOOGLE_OAUTH_CLIENT_SECRET_FILE=credentials/client_secret_<your-client-id>.apps.googleusercontent.com.json
GOOGLE_OAUTH_TOKEN_FILE=credentials/google-token.json

# ── Ollama (local, optional) ──────────────────────────────────────────────────
# OLLAMA_MODEL=gpt-oss:20b
# OLLAMA_QUALITY_MODEL=
# OLLAMA_REFLECTION_MODEL=

# ── OpenAI (optional) ─────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── Gemini (optional) ─────────────────────────────────────────────────────────
# GEMINI_MODEL=gemini-2.5-flash
# GOOGLE_GENAI_CLIENT_SECRET_FILE=

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string-before-deploying
